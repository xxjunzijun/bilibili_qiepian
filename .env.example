APP_HOST=0.0.0.0
APP_PORT=8787
APP_DATA_DIR=./data
APP_RECORDINGS_DIR=./recordings
APP_CHECK_INTERVAL_SECONDS=60

# Recording command template. Available variables:
# {url} {output} {streamer_name} {room_id}
RECORD_COMMAND=streamlink --retry-streams 60 --retry-max 3 "{url}" best -o "{output}"

# Upload command template. Available variables:
# {file} {title} {description} {tags} {tid} {source}
# Keep it empty to leave finished recordings in the "pending_upload" state.
UPLOAD_COMMAND=biliup --user-cookie ./data/cookies.json upload --copyright 2 --tid {tid} --tag "{tags}" --title "{title}" --desc "{description}" "{file}"

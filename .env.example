APP_HOST=0.0.0.0
APP_PORT=8787
APP_DATA_DIR=./data
APP_RECORDINGS_DIR=./recordings
APP_CHECK_INTERVAL_SECONDS=60
# Optional. Leave empty to use the default route interface. Example: eth0, ens3, enp1s0.
APP_NETWORK_INTERFACE=

# Recording command template. Available variables:
# {url} {output} {streamer_name} {room_id} {quality}
RECORD_COMMAND=streamlink --retry-streams 60 --retry-max 3 "{url}" "{quality}" -o "{output}"

# Upload command template. Available variables:
# {file} {files} {title} {description} {tags} {tid} {source}
# Keep it empty to leave finished recordings in the "pending_upload" state.
UPLOAD_COMMAND=biliup --user-cookie ./data/cookies.json upload --copyright 2 --tid {tid} --tag "{tags}" --title "{title}" --desc "{description}" {files}
